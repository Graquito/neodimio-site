---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
---
<Layout title="Acerca de · Neodimio" description="Hacemos lo que hay que hacer.">
  <div class="page">
    <Header active="compania" />

    <main class="typewriter-page">
      <h1 class="typewriter" aria-label="Hacemos lo que hay que hacer">
        <span id="typewriter-text"></span><span class="typewriter__cursor" aria-hidden="true"></span>
      </h1>
    </main>

    <footer class="foot">
      <div class="copy">
        <div>2026 © Neodimio</div>
      </div>
      <a href="/legal" class="legal">Legal</a>
    </footer>
  </div>
</Layout>

<script is:inline>
  (function () {
    const PREFIX = "Hacemos ";
    const HIGHLIGHT = "lo que hay que hacer";
    const FULL = PREFIX + HIGHLIGHT;
    const el = document.getElementById("typewriter-text");
    if (!el) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      el.innerHTML = PREFIX + '<span class="typewriter__highlight" data-state="unselected">' + HIGHLIGHT + '</span>';
      return;
    }

    const wait = (ms) => new Promise((r) => setTimeout(r, ms));

    async function run() {
      while (true) {
        el.textContent = "";
        for (let i = 1; i <= FULL.length; i++) {
          el.textContent = FULL.slice(0, i);
          await wait(55 + Math.random() * 40);
        }
        await wait(550);

        el.innerHTML = PREFIX + '<span class="typewriter__highlight" id="typewriter-highlight">' + HIGHLIGHT + '</span>';
        const h = document.getElementById("typewriter-highlight");

        await wait(80);
        h.dataset.state = "selecting";
        await wait(560);

        h.dataset.state = "colored";
        await wait(420);

        h.dataset.state = "unselected";
        await wait(200);

        await wait(1600);

        el.textContent = FULL;
        for (let i = FULL.length - 1; i >= 0; i--) {
          el.textContent = FULL.slice(0, i);
          await wait(24);
        }

        await wait(700);
      }
    }

    setTimeout(run, 400);
  })();
</script>
